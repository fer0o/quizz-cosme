---
import "../styles/global.css";
import { sections } from "../data/categories";
import { BIG_QUIZ_SIZE } from "../data/quiz";

const totalQuestions = sections.reduce((sum, section) => sum + section.questions.length, 0);
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Trivia Cosmetologia</title>
	</head>
	<body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
		<main class="mx-auto flex min-h-screen w-full max-w-4xl items-center px-6 py-10">
			<section class="w-full rounded-2xl border border-slate-800 bg-slate-900/70 p-6 shadow-xl shadow-slate-950/40 backdrop-blur">
				<header class="mb-6">
					<h1 class="text-3xl font-bold">Trivia de Cosmetologia</h1>
					<p class="mt-2 text-sm text-slate-300">Selecciona una seccion para practicar o entra al modo intenso.</p>
					<p class="mt-2 text-xs text-slate-400">{sections.length} secciones | {totalQuestions} preguntas cargadas</p>
				</header>

				<div class="grid gap-3 sm:grid-cols-2">
					<a
						href="/big-quiz"
						class="rounded-xl border border-emerald-400/50 bg-emerald-500/10 p-4 transition hover:border-emerald-300 hover:bg-emerald-500/15 sm:col-span-2"
					>
						<p class="text-sm font-semibold text-emerald-200">Big Quiz Aleatorio</p>
						<p class="mt-1 text-xs text-emerald-100/90">Ronda intensa con {BIG_QUIZ_SIZE} preguntas al azar.</p>
						<p class="mt-3 text-xs text-emerald-300">Mezcla preguntas de todas las secciones</p>
					</a>

					{
						sections.map((section) => (
							<a
								href={`/seccion/${section.id}`}
								class="rounded-xl border border-slate-800 bg-slate-900 p-4 transition hover:border-emerald-400 hover:bg-slate-800"
							>
								<p class="text-sm font-semibold text-slate-100">{section.title}</p>
								<p class="mt-1 text-xs text-slate-300">{section.description}</p>
								<p class="mt-3 text-xs text-emerald-300">{section.questions.length} preguntas</p>
							</a>
						))
					}
				</div>
			</section>
		</main>
	</body>
</html>
